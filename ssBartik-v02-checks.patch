+  structure(list(coef = b, se_ehw = se_ehw, se_cluster = se_cl,
+                 p_ehw = 2 * stats::pnorm(-abs(b / se_ehw)),
+                 conf.low = b - q * se_ehw, conf.high = b + q * se_ehw,
+                 pre_y = pre_y), class = "ssb_pretrend")
